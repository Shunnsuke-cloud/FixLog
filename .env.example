# 環境変数テンプレート
# このファイルをコピーして .env 又は .env.local を作成してください
# 本番環境では機密情報を適切に管理してください

# ===== バックエンド設定 =====

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fixlog

# JWT
JWT_SECRET=your_super_secret_key_change_me_in_production
JWT_EXPIRATION=7d

# API
PORT=5000
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:3000

# ===== フロントエンド設定 =====

# API
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# App
NEXT_PUBLIC_APP_NAME=FixLog
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_DESCRIPTION=エンジニア向けナレッジ共有Webアプリケーション

# ===== オプション設定 =====

# Email（将来実装）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password

# Cloud Storage（将来実装）
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Analytics（将来実装）
GOOGLE_ANALYTICS_ID=
